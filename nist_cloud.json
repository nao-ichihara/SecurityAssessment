{
  "id": "nist_cloud",
  "label": "NIST SP 800-53 / CIS Controls",
  "sublabel": "クラウド型",
  "frameworks": [
    "NIST SP 800-53 Rev.5",
    "CIS Controls v8",
    "CSA CCM v4"
  ],
  "sections": [
    {
      "id": "s1",
      "label": "アクセス制御",
      "ref": "NIST AC / CIS 5,6",
      "subsections": [
        {
          "title": "アカウント管理",
          "questions": [
            {
              "no": "1.1",
              "text": "全ユーザーアカウントは一意のIDで管理されており、共有アカウントは利用していない",
              "refs": [
                "NIST AC-2",
                "CIS 5.1"
              ]
            },
            {
              "no": "1.2",
              "text": "退職・異動した社員のアカウントは、当日または翌営業日以内に無効化・削除している",
              "refs": [
                "NIST AC-2(3)",
                "CIS 5.3"
              ]
            },
            {
              "no": "1.3",
              "text": "特権アカウント（管理者権限）は最小限のユーザーに限定し、台帳で管理している",
              "refs": [
                "NIST AC-2",
                "NIST AC-6",
                "CIS 5.4"
              ]
            },
            {
              "no": "1.4",
              "text": "ゲストアカウントや不要なデフォルトアカウントは無効化されている",
              "refs": [
                "NIST AC-2(9)",
                "CIS 5.2"
              ]
            },
            {
              "no": "1.5",
              "text": "アカウントの棚卸しを定期的（少なくとも四半期に1回）実施している",
              "refs": [
                "NIST AC-2(3)",
                "CIS 5.6"
              ]
            }
          ]
        },
        {
          "title": "認証・パスワード管理",
          "questions": [
            {
              "no": "1.6",
              "text": "全システムに多要素認証（MFA）が導入されており、特権アカウントは必須となっている",
              "refs": [
                "NIST IA-2(1)",
                "NIST IA-2(2)",
                "CIS 6.3",
                "CIS 6.5"
              ]
            },
            {
              "no": "1.7",
              "text": "パスワードポリシーが定められており（最低文字数・複雑性・有効期限）全システムに適用されている",
              "refs": [
                "NIST IA-5(1)",
                "CIS 5.2"
              ]
            },
            {
              "no": "1.8",
              "text": "パスワードはハッシュ化（bcrypt等）した上で管理されており、平文保存はしていない",
              "refs": [
                "NIST IA-5(1)(c)",
                "CIS 3.11"
              ]
            }
          ]
        },
        {
          "title": "最小権限・職務分離",
          "questions": [
            {
              "no": "1.9",
              "text": "ユーザーには業務上必要最小限の権限のみ付与している（最小権限の原則）",
              "refs": [
                "NIST AC-6",
                "CIS 5.4"
              ]
            },
            {
              "no": "1.10",
              "text": "権限付与・変更にはシステムオーナーまたは管理者による承認プロセスがある",
              "refs": [
                "NIST AC-2(7)",
                "CIS 5.4"
              ]
            },
            {
              "no": "1.11",
              "text": "財務処理やシステム変更などの重要作業で職務分離（Segregation of Duties）を実施している",
              "refs": [
                "NIST AC-5",
                "CIS 5.4"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "s2",
      "label": "脆弱性管理",
      "ref": "NIST SI-2, RA-5 / CIS 7",
      "subsections": [
        {
          "title": "パッチ管理",
          "questions": [
            {
              "no": "2.1",
              "text": "OSおよびアプリケーションのセキュリティパッチを定期的（月次以内）に適用している",
              "refs": [
                "NIST SI-2",
                "CIS 7.3",
                "CIS 7.4"
              ]
            },
            {
              "no": "2.2",
              "text": "緊急パッチ（CVSS Score 9.0以上等）は優先的に72時間以内に対応するプロセスがある",
              "refs": [
                "NIST SI-2(2)",
                "CIS 7.4"
              ]
            },
            {
              "no": "2.3",
              "text": "パッチ適用の実績を記録・管理しており、未適用システムが把握できる",
              "refs": [
                "NIST SI-2",
                "CIS 7.1"
              ]
            }
          ]
        },
        {
          "title": "脆弱性スキャン・ペネトレーションテスト",
          "questions": [
            {
              "no": "2.4",
              "text": "脆弱性スキャンを定期的（少なくとも四半期に1回）実施している",
              "refs": [
                "NIST RA-5",
                "CIS 7.5",
                "CIS 7.6"
              ]
            },
            {
              "no": "2.5",
              "text": "スキャン結果はリスクに基づき優先順位を付けて管理・対応している",
              "refs": [
                "NIST RA-5(d)",
                "CIS 7.5"
              ]
            },
            {
              "no": "2.6",
              "text": "年1回以上の外部ペネトレーションテストを実施している",
              "refs": [
                "NIST CA-8",
                "CIS 18.1"
              ]
            },
            {
              "no": "2.7",
              "text": "Webアプリケーションの脆弱性診断（OWASP Top 10を含む）を実施している",
              "refs": [
                "NIST SA-11",
                "CIS 16.12"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "s3",
      "label": "ログ・監視",
      "ref": "NIST AU / CIS 8",
      "subsections": [
        {
          "title": "ログ収集・保管",
          "questions": [
            {
              "no": "3.1",
              "text": "重要システムの認証・操作・変更ログを一元的に収集・保管している",
              "refs": [
                "NIST AU-2",
                "NIST AU-3",
                "CIS 8.2"
              ]
            },
            {
              "no": "3.2",
              "text": "ログは改ざん防止の措置を施した上で、最低1年以上保管している",
              "refs": [
                "NIST AU-9",
                "NIST AU-11",
                "CIS 8.3"
              ]
            },
            {
              "no": "3.3",
              "text": "ログの収集対象・保管期間・管理責任者がポリシーで定められている",
              "refs": [
                "NIST AU-1",
                "NIST AU-2",
                "CIS 8.1"
              ]
            }
          ]
        },
        {
          "title": "セキュリティ監視",
          "questions": [
            {
              "no": "3.4",
              "text": "リアルタイムの脅威検知・アラート機能が整備されている",
              "refs": [
                "NIST SI-4",
                "CIS 8.11"
              ]
            },
            {
              "no": "3.5",
              "text": "アラートの対応手順（Playbook）が整備され、担当者が訓練を受けている",
              "refs": [
                "NIST IR-4",
                "NIST SI-4",
                "CIS 17.4"
              ]
            },
            {
              "no": "3.6",
              "text": "特権ユーザーの操作ログを特別に記録・定期監査している",
              "refs": [
                "NIST AC-6(9)",
                "NIST AU-2",
                "CIS 8.5"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "s4",
      "label": "データ保護",
      "ref": "NIST SC-28, MP / CIS 3",
      "subsections": [
        {
          "title": "データ分類・管理",
          "questions": [
            {
              "no": "4.1",
              "text": "取り扱う情報の機密レベル分類（公開・社内・機密・極秘等）が定められている",
              "refs": [
                "NIST RA-2",
                "CIS 3.1",
                "CIS 3.2"
              ]
            },
            {
              "no": "4.2",
              "text": "個人情報・顧客データ・機密データの所在（保管場所・システム）が把握されている",
              "refs": [
                "NIST CM-8",
                "CIS 3.1"
              ]
            },
            {
              "no": "4.3",
              "text": "不要になったデータの安全な廃棄手順（データ消去・メディア廃棄）が定められている",
              "refs": [
                "NIST MP-6",
                "CIS 3.7"
              ]
            }
          ]
        },
        {
          "title": "暗号化",
          "questions": [
            {
              "no": "4.4",
              "text": "保存データ（データベース・ストレージ等）が暗号化されている",
              "refs": [
                "NIST SC-28",
                "CIS 3.11"
              ]
            },
            {
              "no": "4.5",
              "text": "通信データはTLS 1.2以上で暗号化されている",
              "refs": [
                "NIST SC-8",
                "CIS 3.10"
              ]
            },
            {
              "no": "4.6",
              "text": "暗号鍵の生成・保管・ローテーション・廃棄の管理手順が整備されている",
              "refs": [
                "NIST SC-12",
                "CIS 3.11"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "s5",
      "label": "インシデント対応",
      "ref": "NIST IR / CIS 17",
      "subsections": [
        {
          "title": "インシデント対応計画",
          "questions": [
            {
              "no": "5.1",
              "text": "インシデント対応計画（IRP）が文書化されており、最新版が維持されている",
              "refs": [
                "NIST IR-1",
                "NIST IR-8",
                "CIS 17.1"
              ]
            },
            {
              "no": "5.2",
              "text": "インシデントの定義・分類（重大度レベル）・対応手順がPlaybookとして整備されている",
              "refs": [
                "NIST IR-4",
                "NIST IR-8",
                "CIS 17.4"
              ]
            },
            {
              "no": "5.3",
              "text": "インシデント対応チーム（CSIRT等）が組織的に設置されている",
              "refs": [
                "NIST IR-2",
                "NIST IR-10",
                "CIS 17.2"
              ]
            },
            {
              "no": "5.4",
              "text": "インシデント対応訓練（机上演習・模擬攻撃等）を年1回以上実施している",
              "refs": [
                "NIST IR-3",
                "NIST CP-4",
                "CIS 17.3"
              ]
            }
          ]
        },
        {
          "title": "インシデント報告・復旧",
          "questions": [
            {
              "no": "5.5",
              "text": "インシデント発生時の社内報告ライン・エスカレーション経路が明確化されている",
              "refs": [
                "NIST IR-6",
                "CIS 17.4"
              ]
            },
            {
              "no": "5.6",
              "text": "規制要件（個人情報保護法等）に基づく行政機関・顧客への通知手順が整備されている",
              "refs": [
                "NIST IR-6(1)",
                "CIS 17.6"
              ]
            },
            {
              "no": "5.7",
              "text": "インシデント後のレビュー（事後分析・再発防止策）を毎回実施し記録している",
              "refs": [
                "NIST IR-4(1)",
                "NIST CA-2",
                "CIS 17.7"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "s6",
      "label": "セキュリティ教育",
      "ref": "NIST AT / CIS 14",
      "subsections": [
        {
          "title": "教育・訓練",
          "questions": [
            {
              "no": "6.1",
              "text": "全従業員向けのセキュリティ基礎教育を入社時と年1回以上定期的に実施している",
              "refs": [
                "NIST AT-2",
                "CIS 14.1",
                "CIS 14.2"
              ]
            },
            {
              "no": "6.2",
              "text": "フィッシングメール訓練を年2回以上実施し、結果をフィードバックしている",
              "refs": [
                "NIST AT-2(2)",
                "CIS 14.2"
              ]
            },
            {
              "no": "6.3",
              "text": "管理職・IT担当者・開発者など役割別の専門教育が行われている",
              "refs": [
                "NIST AT-3",
                "CIS 14.4"
              ]
            },
            {
              "no": "6.4",
              "text": "教育の受講状況を記録・管理しており、未受講者への対応ルールがある",
              "refs": [
                "NIST AT-4",
                "CIS 14.9"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "s7",
      "label": "サプライチェーン",
      "ref": "NIST SR / CIS 15",
      "subsections": [
        {
          "title": "ベンダー管理",
          "questions": [
            {
              "no": "7.1",
              "text": "重要なベンダー・取引先のセキュリティリスクを評価するプロセスがある",
              "refs": [
                "NIST SR-3",
                "NIST SA-9",
                "CIS 15.1"
              ]
            },
            {
              "no": "7.2",
              "text": "ベンダーとのセキュリティ要件を定めた契約（NDA・セキュリティ条項等）が締結されている",
              "refs": [
                "NIST SA-4",
                "NIST SR-5",
                "CIS 15.3"
              ]
            },
            {
              "no": "7.3",
              "text": "ベンダーへのアクセス権限は最小限とし、契約終了時に速やかに削除している",
              "refs": [
                "NIST AC-6",
                "NIST SA-9",
                "CIS 15.6"
              ]
            },
            {
              "no": "7.4",
              "text": "重要なベンダーのセキュリティ状況を定期的（年1回以上）に再評価している",
              "refs": [
                "NIST SR-6",
                "CIS 15.2"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "s8",
      "label": "BCP・バックアップ",
      "ref": "NIST CP / CIS 11",
      "subsections": [
        {
          "title": "バックアップ管理",
          "questions": [
            {
              "no": "8.1",
              "text": "重要データのバックアップを定期的に取得しており、取得頻度・保管期間がポリシーで定められている",
              "refs": [
                "NIST CP-9",
                "CIS 11.1",
                "CIS 11.2"
              ]
            },
            {
              "no": "8.2",
              "text": "バックアップからの復元テストを定期的（少なくとも年1回）実施している",
              "refs": [
                "NIST CP-9(1)",
                "CIS 11.3"
              ]
            },
            {
              "no": "8.3",
              "text": "ランサムウェア対策として、バックアップの隔離（不変ストレージ等）を実施している",
              "refs": [
                "NIST CP-9(3)",
                "CIS 11.4"
              ]
            }
          ]
        },
        {
          "title": "事業継続計画（BCP/DRP）",
          "questions": [
            {
              "no": "8.4",
              "text": "BCP（事業継続計画）およびDRP（災害復旧計画）が文書化されている",
              "refs": [
                "NIST CP-2",
                "CIS 11.1"
              ]
            },
            {
              "no": "8.5",
              "text": "RTO（目標復旧時間）・RPO（目標復旧時点）が重要システムごとに定義されている",
              "refs": [
                "NIST CP-2(a)",
                "CIS 11.1"
              ]
            },
            {
              "no": "8.6",
              "text": "BCP/DRP訓練を年1回以上実施し、結果を計画に反映している",
              "refs": [
                "NIST CP-4",
                "CIS 11.6"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "c1",
      "label": "クラウド基盤",
      "ref": "NIST SC, CA / CSA CCM",
      "tag": "cloud",
      "subsections": [
        {
          "title": "クラウド構成管理（CSPM）",
          "questions": [
            {
              "no": "C1.1",
              "text": "CSPM（Cloud Security Posture Management）ツールを導入し、誤設定を継続的に検出・修正している",
              "refs": [
                "NIST CA-7",
                "NIST CM-6",
                "CSA CCM DSP-01"
              ]
            },
            {
              "no": "C1.2",
              "text": "パブリッククラウドのセキュリティベースライン（CIS Benchmarks等）が適用されている",
              "refs": [
                "NIST CM-6",
                "CIS 4.1",
                "CSA CCM IVS-06"
              ]
            },
            {
              "no": "C1.3",
              "text": "Infrastructure as Code（IaC）にセキュリティチェックを組み込んでいる（例: tfsec, Checkov）",
              "refs": [
                "NIST SA-11",
                "NIST CM-3",
                "CSA CCM DSP-07"
              ]
            },
            {
              "no": "C1.4",
              "text": "クラウドコンソールへのアクセスはMFA必須かつアクセスログを取得している",
              "refs": [
                "NIST IA-2(1)",
                "NIST AU-2",
                "CIS 6.3"
              ]
            },
            {
              "no": "C1.5",
              "text": "クラウド環境の変更はすべてコード管理（GitOps等）で行い、直接手動変更を禁止している",
              "refs": [
                "NIST CM-3",
                "NIST CM-5",
                "CSA CCM CCC-04"
              ]
            }
          ]
        },
        {
          "title": "クラウドID・権限管理（IAM）",
          "questions": [
            {
              "no": "C1.6",
              "text": "クラウドIAMロールには最小権限の原則を適用し、定期的にレビューしている",
              "refs": [
                "NIST AC-6",
                "CIS 5.4",
                "CSA CCM IAM-06"
              ]
            },
            {
              "no": "C1.7",
              "text": "サービスアカウント・APIキー・アクセスキーは定期ローテーションしており、長期固定キーを使用していない",
              "refs": [
                "NIST IA-5(1)",
                "NIST AC-2",
                "CSA CCM IAM-09"
              ]
            },
            {
              "no": "C1.8",
              "text": "クラウドルートアカウントの利用を通常業務では禁止し、MFAを設定している",
              "refs": [
                "NIST AC-6(5)",
                "NIST IA-2(1)",
                "CIS 5.4"
              ]
            },
            {
              "no": "C1.9",
              "text": "IDaaSまたはEntra ID等でシングルサインオン（SSO）を構成している",
              "refs": [
                "NIST IA-8",
                "NIST AC-17",
                "CSA CCM IAM-02"
              ]
            }
          ]
        },
        {
          "title": "ネットワーク分離（VPC）",
          "questions": [
            {
              "no": "C1.10",
              "text": "VPC/VNet等でネットワークを論理分離し、環境（本番・開発・検証）を分けている",
              "refs": [
                "NIST SC-7(13)",
                "CIS 12.2",
                "CSA CCM IVS-01"
              ]
            },
            {
              "no": "C1.11",
              "text": "セキュリティグループ・NACLで不要なインバウンドポートを遮断しており、全開放（0.0.0.0/0）は禁止されている",
              "refs": [
                "NIST SC-7",
                "CIS 12.2",
                "CSA CCM IVS-09"
              ]
            },
            {
              "no": "C1.12",
              "text": "クラウド環境とオフィスネットワークの接続にはVPN/専用線またはZero Trustを採用している",
              "refs": [
                "NIST SC-7",
                "NIST AC-17",
                "CSA CCM IVS-06"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "c2",
      "label": "SaaS・外部サービス",
      "ref": "NIST SR, AC / CIS 15",
      "tag": "cloud",
      "subsections": [
        {
          "title": "SaaS利用管理",
          "questions": [
            {
              "no": "C2.1",
              "text": "利用中のSaaSサービス一覧を管理しており、承認されていないSaaSの利用（シャドーIT）を検出している",
              "refs": [
                "NIST CM-8",
                "NIST SR-3",
                "CSA CCM STA-01"
              ]
            },
            {
              "no": "C2.2",
              "text": "SaaS各サービスのSSO連携・MFA適用状況を把握し、スタンドアロンパスワードのみの利用を排除している",
              "refs": [
                "NIST IA-2(1)",
                "NIST AC-2",
                "CSA CCM IAM-02"
              ]
            },
            {
              "no": "C2.3",
              "text": "SaaSの契約終了・従業員退職時に、アカウント削除・データ削除を確実に実施する手順がある",
              "refs": [
                "NIST AC-2(3)",
                "NIST SR-8",
                "CIS 5.3"
              ]
            },
            {
              "no": "C2.4",
              "text": "SaaSが保存・処理するデータの機密レベルに基づき、利用可否を判断する基準がある",
              "refs": [
                "NIST RA-2",
                "NIST SR-5",
                "CSA CCM DSP-01"
              ]
            }
          ]
        },
        {
          "title": "クラウドデータ保護",
          "questions": [
            {
              "no": "C2.5",
              "text": "クラウドストレージのアクセス制御を定期的にレビューし、パブリック公開設定がないことを確認している",
              "refs": [
                "NIST AC-3",
                "NIST SC-28",
                "CSA CCM DSP-05"
              ]
            },
            {
              "no": "C2.6",
              "text": "クラウド上の機密データには保存時暗号化（SSE）および顧客管理鍵（CMK/BYOK）を適用している",
              "refs": [
                "NIST SC-28",
                "NIST SC-12",
                "CSA CCM CEK-03"
              ]
            },
            {
              "no": "C2.7",
              "text": "DLP（Data Loss Prevention）ツールを用いてクラウド上の機密データ漏洩を検出する仕組みがある",
              "refs": [
                "NIST SI-4",
                "NIST SC-28",
                "CSA CCM DSP-07"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "c3",
      "label": "DevSecOps・コンテナ",
      "ref": "NIST SA / CIS 4,7",
      "tag": "cloud",
      "subsections": [
        {
          "title": "CI/CDパイプラインセキュリティ",
          "questions": [
            {
              "no": "C3.1",
              "text": "CI/CDパイプラインにSAST/DAST/SCAのセキュリティスキャンを組み込んでいる",
              "refs": [
                "NIST SA-11",
                "NIST SA-15",
                "CIS 16.14"
              ]
            },
            {
              "no": "C3.2",
              "text": "シークレット（APIキー・パスワード等）はソースコードやリポジトリに含めず、シークレット管理ツール（Vault等）で管理している",
              "refs": [
                "NIST IA-5",
                "NIST SC-28",
                "CIS 14.8"
              ]
            },
            {
              "no": "C3.3",
              "text": "本番環境へのデプロイには承認プロセス（Pull Requestレビュー・承認者設定）がある",
              "refs": [
                "NIST CM-3",
                "NIST CM-5",
                "CIS 4.2"
              ]
            }
          ]
        },
        {
          "title": "コンテナ・Kubernetesセキュリティ",
          "questions": [
            {
              "no": "C3.4",
              "text": "コンテナイメージは脆弱性スキャンを実施し、重大な脆弱性を含むイメージをデプロイしない",
              "refs": [
                "NIST RA-5",
                "NIST SI-2",
                "CIS 7.5"
              ]
            },
            {
              "no": "C3.5",
              "text": "コンテナはrootユーザーでの実行を禁止し、最小権限で動作させている",
              "refs": [
                "NIST AC-6",
                "NIST CM-7",
                "CIS 5.4"
              ]
            },
            {
              "no": "C3.6",
              "text": "KubernetesのRBAC（Role-Based Access Control）を適切に設定し、不要な権限を付与していない",
              "refs": [
                "NIST AC-3",
                "NIST AC-6",
                "CIS 5.4"
              ]
            },
            {
              "no": "C3.7",
              "text": "ネットワークポリシーでPod間通信を制限し、必要な通信のみを許可している",
              "refs": [
                "NIST SC-7",
                "NIST AC-4",
                "CIS 12.2"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "c4",
      "label": "クラウド資産管理",
      "ref": "NIST CM, CA / CIS 1,2",
      "tag": "cloud",
      "subsections": [
        {
          "title": "クラウド資産・構成管理",
          "questions": [
            {
              "no": "C4.1",
              "text": "クラウド上のリソース（VM・ストレージ・DB等）をすべてタグ付けし、責任者・環境・用途を識別できる",
              "refs": [
                "NIST CM-8",
                "CIS 1.1",
                "CIS 2.1"
              ]
            },
            {
              "no": "C4.2",
              "text": "未使用・孤立したリソース（放置VM・未割当ディスク等）を定期的に検出・削除している",
              "refs": [
                "NIST CM-8(1)",
                "CIS 1.2",
                "CSA CCM IVS-03"
              ]
            },
            {
              "no": "C4.3",
              "text": "クラウドコンプライアンス（SOC2・ISO27001・ISMAP等）の認証状況をベンダーから定期取得・確認している",
              "refs": [
                "NIST CA-2",
                "NIST SR-6",
                "CSA CCM GRC-01"
              ]
            }
          ]
        }
      ]
    }
