{
  "id": "nist_hybrid",
  "label": "NIST SP 800-53 / CIS Controls",
  "sublabel": "ハイブリッド型",
  "frameworks": [
    "NIST SP 800-53 Rev.5",
    "CIS Controls v8",
    "CSA CCM v4",
    "NIST SP 800-207"
  ],
  "sections": [
    {
      "id": "s1",
      "label": "アクセス制御",
      "ref": "NIST AC / CIS 5,6",
      "subsections": [
        {
          "title": "アカウント管理",
          "questions": [
            {
              "no": "1.1",
              "text": "全ユーザーアカウントは一意のIDで管理されており、共有アカウントは利用していない",
              "refs": [
                "NIST AC-2",
                "CIS 5.1"
              ]
            },
            {
              "no": "1.2",
              "text": "退職・異動した社員のアカウントは、当日または翌営業日以内に無効化・削除している",
              "refs": [
                "NIST AC-2(3)",
                "CIS 5.3"
              ]
            },
            {
              "no": "1.3",
              "text": "特権アカウント（管理者権限）は最小限のユーザーに限定し、台帳で管理している",
              "refs": [
                "NIST AC-2",
                "NIST AC-6",
                "CIS 5.4"
              ]
            },
            {
              "no": "1.4",
              "text": "ゲストアカウントや不要なデフォルトアカウントは無効化されている",
              "refs": [
                "NIST AC-2(9)",
                "CIS 5.2"
              ]
            },
            {
              "no": "1.5",
              "text": "アカウントの棚卸しを定期的（少なくとも四半期に1回）実施している",
              "refs": [
                "NIST AC-2(3)",
                "CIS 5.6"
              ]
            }
          ]
        },
        {
          "title": "認証・パスワード管理",
          "questions": [
            {
              "no": "1.6",
              "text": "全システムに多要素認証（MFA）が導入されており、特権アカウントは必須となっている",
              "refs": [
                "NIST IA-2(1)",
                "NIST IA-2(2)",
                "CIS 6.3",
                "CIS 6.5"
              ]
            },
            {
              "no": "1.7",
              "text": "パスワードポリシーが定められており（最低文字数・複雑性・有効期限）全システムに適用されている",
              "refs": [
                "NIST IA-5(1)",
                "CIS 5.2"
              ]
            },
            {
              "no": "1.8",
              "text": "パスワードはハッシュ化（bcrypt等）した上で管理されており、平文保存はしていない",
              "refs": [
                "NIST IA-5(1)(c)",
                "CIS 3.11"
              ]
            }
          ]
        },
        {
          "title": "最小権限・職務分離",
          "questions": [
            {
              "no": "1.9",
              "text": "ユーザーには業務上必要最小限の権限のみ付与している（最小権限の原則）",
              "refs": [
                "NIST AC-6",
                "CIS 5.4"
              ]
            },
            {
              "no": "1.10",
              "text": "権限付与・変更にはシステムオーナーまたは管理者による承認プロセスがある",
              "refs": [
                "NIST AC-2(7)",
                "CIS 5.4"
              ]
            },
            {
              "no": "1.11",
              "text": "財務処理やシステム変更などの重要作業で職務分離（Segregation of Duties）を実施している",
              "refs": [
                "NIST AC-5",
                "CIS 5.4"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "s2",
      "label": "脆弱性管理",
      "ref": "NIST SI-2, RA-5 / CIS 7",
      "subsections": [
        {
          "title": "パッチ管理",
          "questions": [
            {
              "no": "2.1",
              "text": "OSおよびアプリケーションのセキュリティパッチを定期的（月次以内）に適用している",
              "refs": [
                "NIST SI-2",
                "CIS 7.3",
                "CIS 7.4"
              ]
            },
            {
              "no": "2.2",
              "text": "緊急パッチ（CVSS Score 9.0以上等）は優先的に72時間以内に対応するプロセスがある",
              "refs": [
                "NIST SI-2(2)",
                "CIS 7.4"
              ]
            },
            {
              "no": "2.3",
              "text": "パッチ適用の実績を記録・管理しており、未適用システムが把握できる",
              "refs": [
                "NIST SI-2",
                "CIS 7.1"
              ]
            }
          ]
        },
        {
          "title": "脆弱性スキャン・ペネトレーションテスト",
          "questions": [
            {
              "no": "2.4",
              "text": "脆弱性スキャンを定期的（少なくとも四半期に1回）実施している",
              "refs": [
                "NIST RA-5",
                "CIS 7.5",
                "CIS 7.6"
              ]
            },
            {
              "no": "2.5",
              "text": "スキャン結果はリスクに基づき優先順位を付けて管理・対応している",
              "refs": [
                "NIST RA-5(d)",
                "CIS 7.5"
              ]
            },
            {
              "no": "2.6",
              "text": "年1回以上の外部ペネトレーションテストを実施している",
              "refs": [
                "NIST CA-8",
                "CIS 18.1"
              ]
            },
            {
              "no": "2.7",
              "text": "Webアプリケーションの脆弱性診断（OWASP Top 10を含む）を実施している",
              "refs": [
                "NIST SA-11",
                "CIS 16.12"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "s3",
      "label": "ログ・監視",
      "ref": "NIST AU / CIS 8",
      "subsections": [
        {
          "title": "ログ収集・保管",
          "questions": [
            {
              "no": "3.1",
              "text": "重要システムの認証・操作・変更ログを一元的に収集・保管している",
              "refs": [
                "NIST AU-2",
                "NIST AU-3",
                "CIS 8.2"
              ]
            },
            {
              "no": "3.2",
              "text": "ログは改ざん防止の措置を施した上で、最低1年以上保管している",
              "refs": [
                "NIST AU-9",
                "NIST AU-11",
                "CIS 8.3"
              ]
            },
            {
              "no": "3.3",
              "text": "ログの収集対象・保管期間・管理責任者がポリシーで定められている",
              "refs": [
                "NIST AU-1",
                "NIST AU-2",
                "CIS 8.1"
              ]
            }
          ]
        },
        {
          "title": "セキュリティ監視",
          "questions": [
            {
              "no": "3.4",
              "text": "リアルタイムの脅威検知・アラート機能が整備されている",
              "refs": [
                "NIST SI-4",
                "CIS 8.11"
              ]
            },
            {
              "no": "3.5",
              "text": "アラートの対応手順（Playbook）が整備され、担当者が訓練を受けている",
              "refs": [
                "NIST IR-4",
                "NIST SI-4",
                "CIS 17.4"
              ]
            },
            {
              "no": "3.6",
              "text": "特権ユーザーの操作ログを特別に記録・定期監査している",
              "refs": [
                "NIST AC-6(9)",
                "NIST AU-2",
                "CIS 8.5"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "s4",
      "label": "データ保護",
      "ref": "NIST SC-28, MP / CIS 3",
      "subsections": [
        {
          "title": "データ分類・管理",
          "questions": [
            {
              "no": "4.1",
              "text": "取り扱う情報の機密レベル分類（公開・社内・機密・極秘等）が定められている",
              "refs": [
                "NIST RA-2",
                "CIS 3.1",
                "CIS 3.2"
              ]
            },
            {
              "no": "4.2",
              "text": "個人情報・顧客データ・機密データの所在（保管場所・システム）が把握されている",
              "refs": [
                "NIST CM-8",
                "CIS 3.1"
              ]
            },
            {
              "no": "4.3",
              "text": "不要になったデータの安全な廃棄手順（データ消去・メディア廃棄）が定められている",
              "refs": [
                "NIST MP-6",
                "CIS 3.7"
              ]
            }
          ]
        },
        {
          "title": "暗号化",
          "questions": [
            {
              "no": "4.4",
              "text": "保存データ（データベース・ストレージ等）が暗号化されている",
              "refs": [
                "NIST SC-28",
                "CIS 3.11"
              ]
            },
            {
              "no": "4.5",
              "text": "通信データはTLS 1.2以上で暗号化されている",
              "refs": [
                "NIST SC-8",
                "CIS 3.10"
              ]
            },
            {
              "no": "4.6",
              "text": "暗号鍵の生成・保管・ローテーション・廃棄の管理手順が整備されている",
              "refs": [
                "NIST SC-12",
                "CIS 3.11"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "s5",
      "label": "インシデント対応",
      "ref": "NIST IR / CIS 17",
      "subsections": [
        {
          "title": "インシデント対応計画",
          "questions": [
            {
              "no": "5.1",
              "text": "インシデント対応計画（IRP）が文書化されており、最新版が維持されている",
              "refs": [
                "NIST IR-1",
                "NIST IR-8",
                "CIS 17.1"
              ]
            },
            {
              "no": "5.2",
              "text": "インシデントの定義・分類（重大度レベル）・対応手順がPlaybookとして整備されている",
              "refs": [
                "NIST IR-4",
                "NIST IR-8",
                "CIS 17.4"
              ]
            },
            {
              "no": "5.3",
              "text": "インシデント対応チーム（CSIRT等）が組織的に設置されている",
              "refs": [
                "NIST IR-2",
                "NIST IR-10",
                "CIS 17.2"
              ]
            },
            {
              "no": "5.4",
              "text": "インシデント対応訓練（机上演習・模擬攻撃等）を年1回以上実施している",
              "refs": [
                "NIST IR-3",
                "NIST CP-4",
                "CIS 17.3"
              ]
            }
          ]
        },
        {
          "title": "インシデント報告・復旧",
          "questions": [
            {
              "no": "5.5",
              "text": "インシデント発生時の社内報告ライン・エスカレーション経路が明確化されている",
              "refs": [
                "NIST IR-6",
                "CIS 17.4"
              ]
            },
            {
              "no": "5.6",
              "text": "規制要件（個人情報保護法等）に基づく行政機関・顧客への通知手順が整備されている",
              "refs": [
                "NIST IR-6(1)",
                "CIS 17.6"
              ]
            },
            {
              "no": "5.7",
              "text": "インシデント後のレビュー（事後分析・再発防止策）を毎回実施し記録している",
              "refs": [
                "NIST IR-4(1)",
                "NIST CA-2",
                "CIS 17.7"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "s6",
      "label": "セキュリティ教育",
      "ref": "NIST AT / CIS 14",
      "subsections": [
        {
          "title": "教育・訓練",
          "questions": [
            {
              "no": "6.1",
              "text": "全従業員向けのセキュリティ基礎教育を入社時と年1回以上定期的に実施している",
              "refs": [
                "NIST AT-2",
                "CIS 14.1",
                "CIS 14.2"
              ]
            },
            {
              "no": "6.2",
              "text": "フィッシングメール訓練を年2回以上実施し、結果をフィードバックしている",
              "refs": [
                "NIST AT-2(2)",
                "CIS 14.2"
              ]
            },
            {
              "no": "6.3",
              "text": "管理職・IT担当者・開発者など役割別の専門教育が行われている",
              "refs": [
                "NIST AT-3",
                "CIS 14.4"
              ]
            },
            {
              "no": "6.4",
              "text": "教育の受講状況を記録・管理しており、未受講者への対応ルールがある",
              "refs": [
                "NIST AT-4",
                "CIS 14.9"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "s7",
      "label": "サプライチェーン",
      "ref": "NIST SR / CIS 15",
      "subsections": [
        {
          "title": "ベンダー管理",
          "questions": [
            {
              "no": "7.1",
              "text": "重要なベンダー・取引先のセキュリティリスクを評価するプロセスがある",
              "refs": [
                "NIST SR-3",
                "NIST SA-9",
                "CIS 15.1"
              ]
            },
            {
              "no": "7.2",
              "text": "ベンダーとのセキュリティ要件を定めた契約（NDA・セキュリティ条項等）が締結されている",
              "refs": [
                "NIST SA-4",
                "NIST SR-5",
                "CIS 15.3"
              ]
            },
            {
              "no": "7.3",
              "text": "ベンダーへのアクセス権限は最小限とし、契約終了時に速やかに削除している",
              "refs": [
                "NIST AC-6",
                "NIST SA-9",
                "CIS 15.6"
              ]
            },
            {
              "no": "7.4",
              "text": "重要なベンダーのセキュリティ状況を定期的（年1回以上）に再評価している",
              "refs": [
                "NIST SR-6",
                "CIS 15.2"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "s8",
      "label": "BCP・バックアップ",
      "ref": "NIST CP / CIS 11",
      "subsections": [
        {
          "title": "バックアップ管理",
          "questions": [
            {
              "no": "8.1",
              "text": "重要データのバックアップを定期的に取得しており、取得頻度・保管期間がポリシーで定められている",
              "refs": [
                "NIST CP-9",
                "CIS 11.1",
                "CIS 11.2"
              ]
            },
            {
              "no": "8.2",
              "text": "バックアップからの復元テストを定期的（少なくとも年1回）実施している",
              "refs": [
                "NIST CP-9(1)",
                "CIS 11.3"
              ]
            },
            {
              "no": "8.3",
              "text": "ランサムウェア対策として、バックアップの隔離（不変ストレージ等）を実施している",
              "refs": [
                "NIST CP-9(3)",
                "CIS 11.4"
              ]
            }
          ]
        },
        {
          "title": "事業継続計画（BCP/DRP）",
          "questions": [
            {
              "no": "8.4",
              "text": "BCP（事業継続計画）およびDRP（災害復旧計画）が文書化されている",
              "refs": [
                "NIST CP-2",
                "CIS 11.1"
              ]
            },
            {
              "no": "8.5",
              "text": "RTO（目標復旧時間）・RPO（目標復旧時点）が重要システムごとに定義されている",
              "refs": [
                "NIST CP-2(a)",
                "CIS 11.1"
              ]
            },
            {
              "no": "8.6",
              "text": "BCP/DRP訓練を年1回以上実施し、結果を計画に反映している",
              "refs": [
                "NIST CP-4",
                "CIS 11.6"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "h1",
      "label": "クラウド側",
      "ref": "NIST SC, AC / CSA CCM",
      "tag": "hybrid",
      "subsections": [
        {
          "title": "クラウド構成管理",
          "questions": [
            {
              "no": "H1.1",
              "text": "CSPM（Cloud Security Posture Management）ツールを導入し、クラウド側の誤設定を継続的に検出・修正している",
              "refs": [
                "NIST CA-7",
                "NIST CM-6",
                "CSA CCM DSP-01"
              ]
            },
            {
              "no": "H1.2",
              "text": "クラウドIAMロールには最小権限を適用し、サービスアカウント・APIキーを定期ローテーションしている",
              "refs": [
                "NIST AC-6",
                "NIST IA-5(1)",
                "CSA CCM IAM-06"
              ]
            },
            {
              "no": "H1.3",
              "text": "クラウドのセキュリティベースライン（CIS Benchmarks等）が各クラウドプラットフォームに適用されている",
              "refs": [
                "NIST CM-6",
                "CIS 4.1",
                "CSA CCM IVS-06"
              ]
            },
            {
              "no": "H1.4",
              "text": "利用中のSaaSサービス一覧を管理しており、未承認のシャドーITを検出する仕組みがある",
              "refs": [
                "NIST CM-8",
                "NIST SR-3",
                "CSA CCM STA-01"
              ]
            }
          ]
        },
        {
          "title": "クラウドデータ保護",
          "questions": [
            {
              "no": "H1.5",
              "text": "クラウドストレージのアクセス制御を定期レビューし、不要なパブリック公開設定がないことを確認している",
              "refs": [
                "NIST AC-3",
                "NIST SC-28",
                "CSA CCM DSP-05"
              ]
            },
            {
              "no": "H1.6",
              "text": "クラウド上の機密データに保存時暗号化（SSE/CMK）を適用している",
              "refs": [
                "NIST SC-28",
                "NIST SC-12",
                "CSA CCM CEK-03"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "h2",
      "label": "オンプレミス側",
      "ref": "NIST CM, SC / CIS 1,2,12",
      "tag": "hybrid",
      "subsections": [
        {
          "title": "物理セキュリティ・資産管理",
          "questions": [
            {
              "no": "H2.1",
              "text": "データセンター・サーバールームへの入退室管理（ICカード・生体認証等）が実施されている",
              "refs": [
                "NIST PE-3",
                "NIST PE-6",
                "CIS 10.1"
              ]
            },
            {
              "no": "H2.2",
              "text": "オンプレミスのハードウェア資産台帳が最新化されており、EOL機器を把握・管理している",
              "refs": [
                "NIST CM-8",
                "CIS 1.1",
                "CIS 2.1"
              ]
            },
            {
              "no": "H2.3",
              "text": "サーバー・ネットワーク機器のファームウェアを定期的にアップデートしている",
              "refs": [
                "NIST SI-2",
                "NIST CM-6",
                "CIS 7.3"
              ]
            }
          ]
        },
        {
          "title": "オンプレミスネットワーク",
          "questions": [
            {
              "no": "H2.4",
              "text": "次世代ファイアウォール（NGFW）またはUTMを導入し、不要なポート・通信を遮断している",
              "refs": [
                "NIST SC-7",
                "CIS 12.2",
                "CIS 13.4"
              ]
            },
            {
              "no": "H2.5",
              "text": "ネットワークはVLAN等でセグメント分割しており、重要システムは隔離されている",
              "refs": [
                "NIST SC-7(13)",
                "CIS 12.2"
              ]
            },
            {
              "no": "H2.6",
              "text": "内部ネットワークでの不正横断移動（ラテラルムーブメント）を検出するIDS/IPSを導入している",
              "refs": [
                "NIST SI-4",
                "NIST SC-7",
                "CIS 13.3"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "h3",
      "label": "統合管理",
      "ref": "NIST SC, CA / CIS 12,13",
      "tag": "hybrid",
      "subsections": [
        {
          "title": "接続セキュリティ",
          "questions": [
            {
              "no": "H3.1",
              "text": "クラウドとオンプレミス間の接続には専用線（ExpressRoute/DirectConnect等）またはIPSec VPNを採用している",
              "refs": [
                "NIST SC-7",
                "NIST AC-17",
                "CSA CCM IVS-06"
              ]
            },
            {
              "no": "H3.2",
              "text": "クラウド−オンプレミス間のトラフィックを監視しており、異常通信を検出する仕組みがある",
              "refs": [
                "NIST SI-4",
                "NIST SC-7",
                "CIS 13.1"
              ]
            },
            {
              "no": "H3.3",
              "text": "接続経路の冗長化を実施しており、単一障害点（SPOF）がない設計になっている",
              "refs": [
                "NIST CP-8",
                "NIST SC-5",
                "CSA CCM IVS-08"
              ]
            },
            {
              "no": "H3.4",
              "text": "クラウドとオンプレミスのデータ同期・レプリケーション経路は暗号化されている",
              "refs": [
                "NIST SC-8",
                "NIST SC-28",
                "CSA CCM CEK-01"
              ]
            }
          ]
        },
        {
          "title": "統合ID管理・認証",
          "questions": [
            {
              "no": "H3.5",
              "text": "オンプレミスのActive DirectoryとクラウドIDプロバイダー（Entra ID等）のID同期・フェデレーションを安全に構成している",
              "refs": [
                "NIST IA-8",
                "NIST AC-2",
                "CSA CCM IAM-02"
              ]
            },
            {
              "no": "H3.6",
              "text": "ハイブリッド環境全体で一貫したMFAポリシーが適用されており、クラウド・オンプレミス双方で抜け穴がない",
              "refs": [
                "NIST IA-2(1)",
                "NIST IA-2(2)",
                "CIS 6.3"
              ]
            },
            {
              "no": "H3.7",
              "text": "特権アカウント（ハイブリッドAD管理者・クラウドルート等）は環境をまたいで最小限に絞り、PAMツールで管理している",
              "refs": [
                "NIST AC-6(5)",
                "NIST AC-2",
                "CIS 5.4"
              ]
            }
          ]
        },
        {
          "title": "統合監視・ログ管理",
          "questions": [
            {
              "no": "H3.8",
              "text": "クラウドとオンプレミス双方のログを一元的なSIEM/SOCに集約して監視している",
              "refs": [
                "NIST AU-2",
                "NIST SI-4",
                "CIS 8.2"
              ]
            },
            {
              "no": "H3.9",
              "text": "クラウド側とオンプレミス側の時刻同期（NTP）が統一されており、ログ相関分析に支障がない",
              "refs": [
                "NIST AU-8",
                "CIS 8.4"
              ]
            },
            {
              "no": "H3.10",
              "text": "セキュリティポリシー（パッチ管理・設定基準等）がクラウドとオンプレミスで統一・整合されている",
              "refs": [
                "NIST CM-6",
                "NIST PL-2",
                "CIS 4.1"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "h4",
      "label": "ゼロトラスト",
      "ref": "NIST AC, SC / SP 800-207",
      "tag": "hybrid",
      "subsections": [
        {
          "title": "リモートアクセス",
          "questions": [
            {
              "no": "H4.1",
              "text": "リモートワーク時のオンプレミスシステムへのアクセスにはVPNまたはZTNA（ゼロトラストネットワークアクセス）を利用している",
              "refs": [
                "NIST AC-17",
                "NIST SP 800-207",
                "CIS 12.5"
              ]
            },
            {
              "no": "H4.2",
              "text": "VPNの代替としてZTNA（例: Zscaler, Cloudflare Access等）への移行計画がある、または移行済みである",
              "refs": [
                "NIST AC-17",
                "NIST SP 800-207",
                "CSA CCM IVS-06"
              ]
            },
            {
              "no": "H4.3",
              "text": "エンドポイントデバイスの健全性（OS更新・EDR導入等）を確認した上でアクセスを許可する仕組み（デバイスコンプライアンスチェック）がある",
              "refs": [
                "NIST IA-3",
                "NIST CM-6",
                "NIST SP 800-207"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "h5",
      "label": "資産・エンドポイント",
      "ref": "NIST CM / CIS 1,2",
      "tag": "hybrid",
      "subsections": [
        {
          "title": "統合資産管理",
          "questions": [
            {
              "no": "H5.1",
              "text": "オンプレミスとクラウド双方の資産（ハードウェア・VM・コンテナ等）を統合した台帳で管理している",
              "refs": [
                "NIST CM-8",
                "CIS 1.1",
                "CIS 2.1"
              ]
            },
            {
              "no": "H5.2",
              "text": "エンドポイント（PC・モバイル）はMDM/UEMで一元管理し、クラウド・社内双方のポリシーを適用している",
              "refs": [
                "NIST CM-6",
                "NIST AC-19",
                "CIS 4.2"
              ]
            },
            {
              "no": "H5.3",
              "text": "EDR（Endpoint Detection and Response）ツールを全エンドポイントに導入し、クラウドコンソールで一元管理している",
              "refs": [
                "NIST SI-3",
                "NIST SI-4",
                "CIS 10.7"
              ]
            }
          ]
        }
      ]
