{
  "id": "nist_onprem",
  "label": "NIST SP 800-53 / CIS Controls",
  "sublabel": "オンプレミス型",
  "frameworks": [
    "NIST SP 800-53 Rev.5",
    "CIS Controls v8"
  ],
  "sections": [
    {
      "id": "s1",
      "label": "アクセス制御",
      "ref": "NIST AC / CIS 5,6",
      "subsections": [
        {
          "title": "アカウント管理",
          "questions": [
            {
              "no": "1.1",
              "text": "全ユーザーアカウントは一意のIDで管理されており、共有アカウントは利用していない",
              "refs": [
                "NIST AC-2",
                "CIS 5.1"
              ]
            },
            {
              "no": "1.2",
              "text": "退職・異動した社員のアカウントは、当日または翌営業日以内に無効化・削除している",
              "refs": [
                "NIST AC-2(3)",
                "CIS 5.3"
              ]
            },
            {
              "no": "1.3",
              "text": "特権アカウント（管理者権限）は最小限のユーザーに限定し、台帳で管理している",
              "refs": [
                "NIST AC-2",
                "NIST AC-6",
                "CIS 5.4"
              ]
            },
            {
              "no": "1.4",
              "text": "ゲストアカウントや不要なデフォルトアカウントは無効化されている",
              "refs": [
                "NIST AC-2(9)",
                "CIS 5.2"
              ]
            },
            {
              "no": "1.5",
              "text": "アカウントの棚卸しを定期的（少なくとも四半期に1回）実施している",
              "refs": [
                "NIST AC-2(3)",
                "CIS 5.6"
              ]
            }
          ]
        },
        {
          "title": "認証・パスワード管理",
          "questions": [
            {
              "no": "1.6",
              "text": "全システムに多要素認証（MFA）が導入されており、特権アカウントは必須となっている",
              "refs": [
                "NIST IA-2(1)",
                "NIST IA-2(2)",
                "CIS 6.3",
                "CIS 6.5"
              ]
            },
            {
              "no": "1.7",
              "text": "パスワードポリシーが定められており（最低文字数・複雑性・有効期限）全システムに適用されている",
              "refs": [
                "NIST IA-5(1)",
                "CIS 5.2"
              ]
            },
            {
              "no": "1.8",
              "text": "パスワードはハッシュ化（bcrypt等）した上で管理されており、平文保存はしていない",
              "refs": [
                "NIST IA-5(1)(c)",
                "CIS 3.11"
              ]
            }
          ]
        },
        {
          "title": "最小権限・職務分離",
          "questions": [
            {
              "no": "1.9",
              "text": "ユーザーには業務上必要最小限の権限のみ付与している（最小権限の原則）",
              "refs": [
                "NIST AC-6",
                "CIS 5.4"
              ]
            },
            {
              "no": "1.10",
              "text": "権限付与・変更にはシステムオーナーまたは管理者による承認プロセスがある",
              "refs": [
                "NIST AC-2(7)",
                "CIS 5.4"
              ]
            },
            {
              "no": "1.11",
              "text": "財務処理やシステム変更などの重要作業で職務分離（Segregation of Duties）を実施している",
              "refs": [
                "NIST AC-5",
                "CIS 5.4"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "s2",
      "label": "脆弱性管理",
      "ref": "NIST SI-2, RA-5 / CIS 7",
      "subsections": [
        {
          "title": "パッチ管理",
          "questions": [
            {
              "no": "2.1",
              "text": "OSおよびアプリケーションのセキュリティパッチを定期的（月次以内）に適用している",
              "refs": [
                "NIST SI-2",
                "CIS 7.3",
                "CIS 7.4"
              ]
            },
            {
              "no": "2.2",
              "text": "緊急パッチ（CVSS Score 9.0以上等）は優先的に72時間以内に対応するプロセスがある",
              "refs": [
                "NIST SI-2(2)",
                "CIS 7.4"
              ]
            },
            {
              "no": "2.3",
              "text": "パッチ適用の実績を記録・管理しており、未適用システムが把握できる",
              "refs": [
                "NIST SI-2",
                "CIS 7.1"
              ]
            }
          ]
        },
        {
          "title": "脆弱性スキャン・ペネトレーションテスト",
          "questions": [
            {
              "no": "2.4",
              "text": "脆弱性スキャンを定期的（少なくとも四半期に1回）実施している",
              "refs": [
                "NIST RA-5",
                "CIS 7.5",
                "CIS 7.6"
              ]
            },
            {
              "no": "2.5",
              "text": "スキャン結果はリスクに基づき優先順位を付けて管理・対応している",
              "refs": [
                "NIST RA-5(d)",
                "CIS 7.5"
              ]
            },
            {
              "no": "2.6",
              "text": "年1回以上の外部ペネトレーションテストを実施している",
              "refs": [
                "NIST CA-8",
                "CIS 18.1"
              ]
            },
            {
              "no": "2.7",
              "text": "Webアプリケーションの脆弱性診断（OWASP Top 10を含む）を実施している",
              "refs": [
                "NIST SA-11",
                "CIS 16.12"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "s3",
      "label": "ログ・監視",
      "ref": "NIST AU / CIS 8",
      "subsections": [
        {
          "title": "ログ収集・保管",
          "questions": [
            {
              "no": "3.1",
              "text": "重要システムの認証・操作・変更ログを一元的に収集・保管している",
              "refs": [
                "NIST AU-2",
                "NIST AU-3",
                "CIS 8.2"
              ]
            },
            {
              "no": "3.2",
              "text": "ログは改ざん防止の措置を施した上で、最低1年以上保管している",
              "refs": [
                "NIST AU-9",
                "NIST AU-11",
                "CIS 8.3"
              ]
            },
            {
              "no": "3.3",
              "text": "ログの収集対象・保管期間・管理責任者がポリシーで定められている",
              "refs": [
                "NIST AU-1",
                "NIST AU-2",
                "CIS 8.1"
              ]
            }
          ]
        },
        {
          "title": "セキュリティ監視",
          "questions": [
            {
              "no": "3.4",
              "text": "リアルタイムの脅威検知・アラート機能が整備されている",
              "refs": [
                "NIST SI-4",
                "CIS 8.11"
              ]
            },
            {
              "no": "3.5",
              "text": "アラートの対応手順（Playbook）が整備され、担当者が訓練を受けている",
              "refs": [
                "NIST IR-4",
                "NIST SI-4",
                "CIS 17.4"
              ]
            },
            {
              "no": "3.6",
              "text": "特権ユーザーの操作ログを特別に記録・定期監査している",
              "refs": [
                "NIST AC-6(9)",
                "NIST AU-2",
                "CIS 8.5"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "s4",
      "label": "データ保護",
      "ref": "NIST SC-28, MP / CIS 3",
      "subsections": [
        {
          "title": "データ分類・管理",
          "questions": [
            {
              "no": "4.1",
              "text": "取り扱う情報の機密レベル分類（公開・社内・機密・極秘等）が定められている",
              "refs": [
                "NIST RA-2",
                "CIS 3.1",
                "CIS 3.2"
              ]
            },
            {
              "no": "4.2",
              "text": "個人情報・顧客データ・機密データの所在（保管場所・システム）が把握されている",
              "refs": [
                "NIST CM-8",
                "CIS 3.1"
              ]
            },
            {
              "no": "4.3",
              "text": "不要になったデータの安全な廃棄手順（データ消去・メディア廃棄）が定められている",
              "refs": [
                "NIST MP-6",
                "CIS 3.7"
              ]
            }
          ]
        },
        {
          "title": "暗号化",
          "questions": [
            {
              "no": "4.4",
              "text": "保存データ（データベース・ストレージ等）が暗号化されている",
              "refs": [
                "NIST SC-28",
                "CIS 3.11"
              ]
            },
            {
              "no": "4.5",
              "text": "通信データはTLS 1.2以上で暗号化されている",
              "refs": [
                "NIST SC-8",
                "CIS 3.10"
              ]
            },
            {
              "no": "4.6",
              "text": "暗号鍵の生成・保管・ローテーション・廃棄の管理手順が整備されている",
              "refs": [
                "NIST SC-12",
                "CIS 3.11"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "s5",
      "label": "インシデント対応",
      "ref": "NIST IR / CIS 17",
      "subsections": [
        {
          "title": "インシデント対応計画",
          "questions": [
            {
              "no": "5.1",
              "text": "インシデント対応計画（IRP）が文書化されており、最新版が維持されている",
              "refs": [
                "NIST IR-1",
                "NIST IR-8",
                "CIS 17.1"
              ]
            },
            {
              "no": "5.2",
              "text": "インシデントの定義・分類（重大度レベル）・対応手順がPlaybookとして整備されている",
              "refs": [
                "NIST IR-4",
                "NIST IR-8",
                "CIS 17.4"
              ]
            },
            {
              "no": "5.3",
              "text": "インシデント対応チーム（CSIRT等）が組織的に設置されている",
              "refs": [
                "NIST IR-2",
                "NIST IR-10",
                "CIS 17.2"
              ]
            },
            {
              "no": "5.4",
              "text": "インシデント対応訓練（机上演習・模擬攻撃等）を年1回以上実施している",
              "refs": [
                "NIST IR-3",
                "NIST CP-4",
                "CIS 17.3"
              ]
            }
          ]
        },
        {
          "title": "インシデント報告・復旧",
          "questions": [
            {
              "no": "5.5",
              "text": "インシデント発生時の社内報告ライン・エスカレーション経路が明確化されている",
              "refs": [
                "NIST IR-6",
                "CIS 17.4"
              ]
            },
            {
              "no": "5.6",
              "text": "規制要件（個人情報保護法等）に基づく行政機関・顧客への通知手順が整備されている",
              "refs": [
                "NIST IR-6(1)",
                "CIS 17.6"
              ]
            },
            {
              "no": "5.7",
              "text": "インシデント後のレビュー（事後分析・再発防止策）を毎回実施し記録している",
              "refs": [
                "NIST IR-4(1)",
                "NIST CA-2",
                "CIS 17.7"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "s6",
      "label": "セキュリティ教育",
      "ref": "NIST AT / CIS 14",
      "subsections": [
        {
          "title": "教育・訓練",
          "questions": [
            {
              "no": "6.1",
              "text": "全従業員向けのセキュリティ基礎教育を入社時と年1回以上定期的に実施している",
              "refs": [
                "NIST AT-2",
                "CIS 14.1",
                "CIS 14.2"
              ]
            },
            {
              "no": "6.2",
              "text": "フィッシングメール訓練を年2回以上実施し、結果をフィードバックしている",
              "refs": [
                "NIST AT-2(2)",
                "CIS 14.2"
              ]
            },
            {
              "no": "6.3",
              "text": "管理職・IT担当者・開発者など役割別の専門教育が行われている",
              "refs": [
                "NIST AT-3",
                "CIS 14.4"
              ]
            },
            {
              "no": "6.4",
              "text": "教育の受講状況を記録・管理しており、未受講者への対応ルールがある",
              "refs": [
                "NIST AT-4",
                "CIS 14.9"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "s7",
      "label": "サプライチェーン",
      "ref": "NIST SR / CIS 15",
      "subsections": [
        {
          "title": "ベンダー管理",
          "questions": [
            {
              "no": "7.1",
              "text": "重要なベンダー・取引先のセキュリティリスクを評価するプロセスがある",
              "refs": [
                "NIST SR-3",
                "NIST SA-9",
                "CIS 15.1"
              ]
            },
            {
              "no": "7.2",
              "text": "ベンダーとのセキュリティ要件を定めた契約（NDA・セキュリティ条項等）が締結されている",
              "refs": [
                "NIST SA-4",
                "NIST SR-5",
                "CIS 15.3"
              ]
            },
            {
              "no": "7.3",
              "text": "ベンダーへのアクセス権限は最小限とし、契約終了時に速やかに削除している",
              "refs": [
                "NIST AC-6",
                "NIST SA-9",
                "CIS 15.6"
              ]
            },
            {
              "no": "7.4",
              "text": "重要なベンダーのセキュリティ状況を定期的（年1回以上）に再評価している",
              "refs": [
                "NIST SR-6",
                "CIS 15.2"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "s8",
      "label": "BCP・バックアップ",
      "ref": "NIST CP / CIS 11",
      "subsections": [
        {
          "title": "バックアップ管理",
          "questions": [
            {
              "no": "8.1",
              "text": "重要データのバックアップを定期的に取得しており、取得頻度・保管期間がポリシーで定められている",
              "refs": [
                "NIST CP-9",
                "CIS 11.1",
                "CIS 11.2"
              ]
            },
            {
              "no": "8.2",
              "text": "バックアップからの復元テストを定期的（少なくとも年1回）実施している",
              "refs": [
                "NIST CP-9(1)",
                "CIS 11.3"
              ]
            },
            {
              "no": "8.3",
              "text": "ランサムウェア対策として、バックアップの隔離（不変ストレージ等）を実施している",
              "refs": [
                "NIST CP-9(3)",
                "CIS 11.4"
              ]
            }
          ]
        },
        {
          "title": "事業継続計画（BCP/DRP）",
          "questions": [
            {
              "no": "8.4",
              "text": "BCP（事業継続計画）およびDRP（災害復旧計画）が文書化されている",
              "refs": [
                "NIST CP-2",
                "CIS 11.1"
              ]
            },
            {
              "no": "8.5",
              "text": "RTO（目標復旧時間）・RPO（目標復旧時点）が重要システムごとに定義されている",
              "refs": [
                "NIST CP-2(a)",
                "CIS 11.1"
              ]
            },
            {
              "no": "8.6",
              "text": "BCP/DRP訓練を年1回以上実施し、結果を計画に反映している",
              "refs": [
                "NIST CP-4",
                "CIS 11.6"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "o1",
      "label": "物理セキュリティ",
      "ref": "NIST PE / CIS 10",
      "tag": "onprem",
      "subsections": [
        {
          "title": "施設・入退室管理",
          "questions": [
            {
              "no": "O1.1",
              "text": "データセンター・サーバールームへの入退室はICカード・生体認証等で管理し、入退室記録を保管している",
              "refs": [
                "NIST PE-3",
                "NIST PE-6",
                "CIS 10.1"
              ]
            },
            {
              "no": "O1.2",
              "text": "サーバールームへのアクセスは業務上必要な最小限の人員に限定し、定期的に見直している",
              "refs": [
                "NIST PE-2",
                "NIST AC-6",
                "CIS 10.1"
              ]
            },
            {
              "no": "O1.3",
              "text": "サーバールームには監視カメラを設置し、映像を一定期間保管している",
              "refs": [
                "NIST PE-6(1)",
                "CIS 10.1"
              ]
            },
            {
              "no": "O1.4",
              "text": "無停電電源装置（UPS）・自家発電設備・空調冗長化などの環境対策が施されている",
              "refs": [
                "NIST PE-9",
                "NIST PE-10",
                "NIST PE-11"
              ]
            },
            {
              "no": "O1.5",
              "text": "訪問者・外部業者のサーバールーム内作業は立会いのもと実施し、記録している",
              "refs": [
                "NIST PE-8",
                "NIST PE-3(3)"
              ]
            }
          ]
        },
        {
          "title": "媒体・機器の管理",
          "questions": [
            {
              "no": "O1.6",
              "text": "USBメモリ・外部記憶媒体の利用は管理ポリシーで制限・記録されている",
              "refs": [
                "NIST MP-7",
                "CIS 10.3"
              ]
            },
            {
              "no": "O1.7",
              "text": "廃棄するサーバー・ストレージのデータ消去手順（物理破壊またはソフトウェア消去の証跡）が整備されている",
              "refs": [
                "NIST MP-6",
                "CIS 10.5"
              ]
            },
            {
              "no": "O1.8",
              "text": "ノートPC・モバイル機器の持ち出しには申請・承認プロセスと暗号化設定が必須となっている",
              "refs": [
                "NIST MP-5",
                "NIST AC-19",
                "CIS 10.4"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "o2",
      "label": "ネットワーク",
      "ref": "NIST SC / CIS 12,13",
      "tag": "onprem",
      "subsections": [
        {
          "title": "境界防御",
          "questions": [
            {
              "no": "O2.1",
              "text": "次世代ファイアウォール（NGFW）またはUTMを導入し、インターネット境界で不要な通信を遮断している",
              "refs": [
                "NIST SC-7",
                "CIS 12.2",
                "CIS 13.4"
              ]
            },
            {
              "no": "O2.2",
              "text": "DMZを設置し、外部公開システムと内部ネットワークを分離している",
              "refs": [
                "NIST SC-7(5)",
                "CIS 12.2"
              ]
            },
            {
              "no": "O2.3",
              "text": "侵入検知・防御システム（IDS/IPS）が導入されており、シグネチャを定期更新している",
              "refs": [
                "NIST SI-3",
                "NIST SI-4",
                "CIS 13.3"
              ]
            },
            {
              "no": "O2.4",
              "text": "WAF（Web Application Firewall）が主要なWebアプリケーションに適用されている",
              "refs": [
                "NIST SC-7",
                "NIST SI-10",
                "CIS 16.13"
              ]
            }
          ]
        },
        {
          "title": "内部ネットワーク管理",
          "questions": [
            {
              "no": "O2.5",
              "text": "ネットワークはVLAN等でセグメント分割しており、重要システム（基幹・財務・人事等）は隔離されている",
              "refs": [
                "NIST SC-7(13)",
                "CIS 12.2"
              ]
            },
            {
              "no": "O2.6",
              "text": "内部ネットワークでのラテラルムーブメント（横方向移動）を制限・検出する仕組みがある",
              "refs": [
                "NIST SC-7",
                "NIST SI-4",
                "CIS 12.8"
              ]
            },
            {
              "no": "O2.7",
              "text": "無線LAN（Wi-Fi）はWPA3またはWPA2-Enterpriseで保護されており、ゲスト用は分離されている",
              "refs": [
                "NIST SC-8",
                "CIS 12.3"
              ]
            },
            {
              "no": "O2.8",
              "text": "ネットワーク機器（スイッチ・ルーター）の管理インターフェースはネットワーク的に隔離・制限されている",
              "refs": [
                "NIST SC-7",
                "CIS 12.6"
              ]
            }
          ]
        },
        {
          "title": "リモートアクセス",
          "questions": [
            {
              "no": "O2.9",
              "text": "リモートアクセスにはIPSec VPNまたはSSL-VPNを採用し、MFAが必須となっている",
              "refs": [
                "NIST AC-17",
                "NIST IA-2(1)",
                "CIS 12.5"
              ]
            },
            {
              "no": "O2.10",
              "text": "VPNの接続元IPアドレスや接続時間を制限・監視しており、異常接続を検知する仕組みがある",
              "refs": [
                "NIST AC-17(1)",
                "NIST SI-4",
                "CIS 12.5"
              ]
            },
            {
              "no": "O2.11",
              "text": "リモートデスクトップ（RDP/VNC等）への直接インターネット公開を禁止している",
              "refs": [
                "NIST SC-7",
                "NIST AC-17",
                "CIS 12.4"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "o3",
      "label": "サーバー管理",
      "ref": "NIST CM, SI / CIS 4,10",
      "tag": "onprem",
      "subsections": [
        {
          "title": "サーバーハードニング",
          "questions": [
            {
              "no": "O3.1",
              "text": "サーバーOSの不要なサービス・ポートを無効化し、セキュリティベースライン（CIS Benchmarks等）を適用している",
              "refs": [
                "NIST CM-6",
                "NIST CM-7",
                "CIS 4.1"
              ]
            },
            {
              "no": "O3.2",
              "text": "サーバーの管理アカウント（Administrator/root）は共有せず、個人アカウントに権限付与している",
              "refs": [
                "NIST AC-2",
                "NIST AC-6",
                "CIS 5.4"
              ]
            },
            {
              "no": "O3.3",
              "text": "サーバーへのアクセスは踏み台サーバー（Bastion Host）またはPAMツール経由に限定している",
              "refs": [
                "NIST AC-17",
                "NIST AC-6(2)",
                "CIS 4.3"
              ]
            },
            {
              "no": "O3.4",
              "text": "マルウェア対策ソフト（AV/EDR）を全サーバーに導入し、定義ファイルを自動更新している",
              "refs": [
                "NIST SI-3",
                "CIS 10.6"
              ]
            }
          ]
        },
        {
          "title": "エンドポイント管理",
          "questions": [
            {
              "no": "O3.5",
              "text": "クライアントPCはドメイン（Active Directory）またはMDMで一元管理し、設定ポリシーを適用している",
              "refs": [
                "NIST CM-6",
                "NIST CM-8",
                "CIS 4.2"
              ]
            },
            {
              "no": "O3.6",
              "text": "EDR（Endpoint Detection and Response）を全PCに導入し、インシデント検知・対応に活用している",
              "refs": [
                "NIST SI-3",
                "NIST SI-4",
                "CIS 10.7"
              ]
            },
            {
              "no": "O3.7",
              "text": "PCの自動ロック・スクリーンセーバー設定（5分以内）が強制適用されている",
              "refs": [
                "NIST AC-11",
                "CIS 4.3"
              ]
            },
            {
              "no": "O3.8",
              "text": "USB・外部メディアの自動実行（AutoRun）を無効化し、利用制限ポリシーを適用している",
              "refs": [
                "NIST MP-7",
                "NIST CM-7",
                "CIS 10.3"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "o4",
      "label": "AD・ID管理",
      "ref": "NIST AC, IA / CIS 5,6",
      "tag": "onprem",
      "subsections": [
        {
          "title": "Active Directory セキュリティ",
          "questions": [
            {
              "no": "O4.1",
              "text": "Active Directoryのドメイン管理者アカウント数を最小限に絞り、日常業務での使用を禁止している",
              "refs": [
                "NIST AC-2",
                "NIST AC-6(5)",
                "CIS 5.4"
              ]
            },
            {
              "no": "O4.2",
              "text": "ADの構成変更・グループポリシー変更のログを取得し、定期監査している",
              "refs": [
                "NIST AU-2",
                "NIST CM-3",
                "CIS 8.5"
              ]
            },
            {
              "no": "O4.3",
              "text": "Kerberoasting・Pass-the-Hash等のAD攻撃への対策（Protected Users等）を講じている",
              "refs": [
                "NIST IA-5",
                "NIST SI-3",
                "CIS 6.3"
              ]
            },
            {
              "no": "O4.4",
              "text": "ADのバックアップを定期取得しており、障害時に復元テストを実施している",
              "refs": [
                "NIST CP-9",
                "NIST CP-4",
                "CIS 11.3"
              ]
            },
            {
              "no": "O4.5",
              "text": "サービスアカウント（gMSA等）はパスワードを自動管理し、不要なサービスアカウントを削除している",
              "refs": [
                "NIST IA-5(1)",
                "NIST AC-2",
                "CIS 5.3"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "o5",
      "label": "バックアップ・DR",
      "ref": "NIST CP / CIS 11",
      "tag": "onprem",
      "subsections": [
        {
          "title": "バックアップ管理（詳細）",
          "questions": [
            {
              "no": "O5.1",
              "text": "バックアップはオフサイト（別拠点・テープ媒体・クラウドストレージ等）に保管している",
              "refs": [
                "NIST CP-9(3)",
                "CIS 11.2"
              ]
            },
            {
              "no": "O5.2",
              "text": "バックアップデータはランサムウェア対策のため、本番ネットワークから切り離した隔離環境（エアギャップ等）に保管している",
              "refs": [
                "NIST CP-9(5)",
                "CIS 11.4"
              ]
            },
            {
              "no": "O5.3",
              "text": "テープ・外部ストレージによるバックアップ媒体を施錠管理し、搬送記録を残している",
              "refs": [
                "NIST MP-5",
                "NIST CP-9",
                "CIS 11.2"
              ]
            },
            {
              "no": "O5.4",
              "text": "バックアップの完全性チェック（ハッシュ検証等）を実施し、改ざんを検出できる仕組みがある",
              "refs": [
                "NIST CP-9(1)",
                "NIST SI-7",
                "CIS 11.3"
              ]
            }
          ]
        },
        {
          "title": "災害復旧（DRP）",
          "questions": [
            {
              "no": "O5.5",
              "text": "HAクラスタリング・フェールオーバー等の高可用性構成を重要システムに適用している",
              "refs": [
                "NIST CP-8",
                "NIST CP-10",
                "CIS 11.6"
              ]
            },
            {
              "no": "O5.6",
              "text": "DR拠点（セカンダリサイト）を確保しており、定期的にフェールオーバー訓練を実施している",
              "refs": [
                "NIST CP-7",
                "NIST CP-4",
                "CIS 11.5"
              ]
            },
            {
              "no": "O5.7",
              "text": "重要システムの復旧優先順位とRTO/RPOを定義し、DRPに記載している",
              "refs": [
                "NIST CP-2",
                "NIST CP-10",
                "CIS 11.1"
              ]
            }
          ]
        }
      ]
    }
  ]
}