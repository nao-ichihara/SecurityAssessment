{
  "id": "nist_csf",
  "label": "NIST Cybersecurity Framework",
  "sublabel": "v2.0 全6機能",
  "frameworks": [
    "NIST CSF v2.0"
  ],
  "sections": [
    {
      "id": "csf_gv",
      "label": "GV. ガバナンス",
      "ref": "GOVERN",
      "subsections": [
        {
          "title": "GV.OC — 組織のコンテキスト",
          "questions": [
            {
              "no": "GV.1",
              "text": "組織のミッション・業務目標・法規制要件・リスク許容度が特定され、セキュリティ戦略の基盤として文書化されている",
              "refs": [
                "CSF GV.OC-01"
              ]
            },
            {
              "no": "GV.2",
              "text": "社内外の利害関係者（経営陣・顧客・規制当局・サプライヤー等）のサイバーセキュリティに関する期待事項を把握し、ポリシーに反映している",
              "refs": [
                "CSF GV.OC-02"
              ]
            },
            {
              "no": "GV.3",
              "text": "法令・規制・契約上のサイバーセキュリティ要件を特定し、コンプライアンス管理プロセスに組み込んでいる",
              "refs": [
                "CSF GV.OC-03"
              ]
            }
          ]
        },
        {
          "title": "GV.RM — リスクマネジメント戦略",
          "questions": [
            {
              "no": "GV.4",
              "text": "組織全体のリスク許容度・リスク選好度が経営層によって承認・文書化され、セキュリティ意思決定の基準となっている",
              "refs": [
                "CSF GV.RM-01"
              ]
            },
            {
              "no": "GV.5",
              "text": "サイバーセキュリティリスクマネジメントの方針・プロセス・手続きが確立され、定期的にレビューされている",
              "refs": [
                "CSF GV.RM-02"
              ]
            },
            {
              "no": "GV.6",
              "text": "サイバーセキュリティリスクマネジメントが、組織全体のリスクマネジメントフレームワークに統合されている",
              "refs": [
                "CSF GV.RM-03"
              ]
            }
          ]
        },
        {
          "title": "GV.RR — 役割・責任・権限",
          "questions": [
            {
              "no": "GV.7",
              "text": "サイバーセキュリティに関する役割・責任・権限が定義され、適切な人員に割り当てられている",
              "refs": [
                "CSF GV.RR-01"
              ]
            },
            {
              "no": "GV.8",
              "text": "経営層がサイバーセキュリティリスクを認識・理解し、必要なリソース（予算・人員・ツール）を確保している",
              "refs": [
                "CSF GV.RR-02"
              ]
            }
          ]
        },
        {
          "title": "GV.PO — ポリシー",
          "questions": [
            {
              "no": "GV.9",
              "text": "サイバーセキュリティポリシーが策定され、経営層によって承認され、全組織に周知されている",
              "refs": [
                "CSF GV.PO-01"
              ]
            },
            {
              "no": "GV.10",
              "text": "ポリシーの遵守状況が定期的にレビューされ、不準拠への対応プロセスが整備されている",
              "refs": [
                "CSF GV.PO-02"
              ]
            }
          ]
        },
        {
          "title": "GV.OV — 監督",
          "questions": [
            {
              "no": "GV.11",
              "text": "サイバーセキュリティリスクの管理状況が経営層に定期的に報告され、戦略的意思決定に活用されている",
              "refs": [
                "CSF GV.OV-01"
              ]
            },
            {
              "no": "GV.12",
              "text": "サイバーセキュリティ施策の有効性が測定・評価され、継続的改善のサイクルに組み込まれている",
              "refs": [
                "CSF GV.OV-02"
              ]
            }
          ]
        },
        {
          "title": "GV.SC — サプライチェーンリスクマネジメント",
          "questions": [
            {
              "no": "GV.13",
              "text": "サプライチェーンのサイバーセキュリティリスクマネジメント方針が確立され、重要なサプライヤーが特定されている",
              "refs": [
                "CSF GV.SC-01"
              ]
            },
            {
              "no": "GV.14",
              "text": "サプライヤー・パートナーとのサイバーセキュリティ要件が契約に明記され、定期的に評価されている",
              "refs": [
                "CSF GV.SC-02"
              ]
            },
            {
              "no": "GV.15",
              "text": "サプライチェーンのインシデントが発生した場合の対応手順が整備されている",
              "refs": [
                "CSF GV.SC-03"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "csf_id",
      "label": "ID. 識別",
      "ref": "IDENTIFY",
      "subsections": [
        {
          "title": "ID.AM — 資産管理",
          "questions": [
            {
              "no": "ID.1",
              "text": "組織が管理するハードウェア・ソフトウェア・データ・システムの資産台帳を整備し、最新状態に維持している",
              "refs": [
                "CSF ID.AM-01"
              ]
            },
            {
              "no": "ID.2",
              "text": "クラウドサービス・SaaS・外部システムを含むデジタル資産と、それらのデータフローが把握・文書化されている",
              "refs": [
                "CSF ID.AM-02"
              ]
            },
            {
              "no": "ID.3",
              "text": "各資産のオーナー・重要度・機密性が定義され、優先度付きで管理されている",
              "refs": [
                "CSF ID.AM-03"
              ]
            },
            {
              "no": "ID.4",
              "text": "外部ネットワーク接続・クラウド利用・IoTデバイスを含む組織のシステム境界が明確に定義されている",
              "refs": [
                "CSF ID.AM-04"
              ]
            }
          ]
        },
        {
          "title": "ID.RA — リスクアセスメント",
          "questions": [
            {
              "no": "ID.5",
              "text": "脅威インテリジェンス（JPCERT・ISACなど）を活用して、組織に関連する脅威情報を継続的に収集・分析している",
              "refs": [
                "CSF ID.RA-01"
              ]
            },
            {
              "no": "ID.6",
              "text": "資産の脆弱性を定期的にスキャン・評価し、リスクレベルに基づいて優先的に対処している",
              "refs": [
                "CSF ID.RA-02"
              ]
            },
            {
              "no": "ID.7",
              "text": "特定された脅威・脆弱性・影響を組み合わせたリスク評価を定期的に実施し、経営層に報告している",
              "refs": [
                "CSF ID.RA-03"
              ]
            },
            {
              "no": "ID.8",
              "text": "サイバーインシデントが業務・財務・法的・評判に与える影響を定量的または定性的に評価している",
              "refs": [
                "CSF ID.RA-04"
              ]
            }
          ]
        },
        {
          "title": "ID.IM — 改善",
          "questions": [
            {
              "no": "ID.9",
              "text": "インシデント・演習・脆弱性評価・監査の結果から得られた教訓がリスク管理プロセスの改善に反映されている",
              "refs": [
                "CSF ID.IM-01"
              ]
            },
            {
              "no": "ID.10",
              "text": "セキュリティ管理策の有効性を評価するための指標（KPI・KRI）が定義・測定されている",
              "refs": [
                "CSF ID.IM-02"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "csf_pr",
      "label": "PR. 保護",
      "ref": "PROTECT",
      "subsections": [
        {
          "title": "PR.AA — IDとアクセス管理",
          "questions": [
            {
              "no": "PR.1",
              "text": "ユーザーIDの発行・変更・失効が適切に管理され、退職・異動時の即時アクセス停止が実施されている",
              "refs": [
                "CSF PR.AA-01"
              ]
            },
            {
              "no": "PR.2",
              "text": "最小権限の原則が適用され、業務上必要な権限のみが付与されている（特権アカウントの最小化含む）",
              "refs": [
                "CSF PR.AA-02"
              ]
            },
            {
              "no": "PR.3",
              "text": "多要素認証（MFA）が特権アカウントおよびリモートアクセスを含む重要システムに適用されている",
              "refs": [
                "CSF PR.AA-03"
              ]
            },
            {
              "no": "PR.4",
              "text": "アクセス権限の定期的なレビューが実施され、不要な権限が削除されている",
              "refs": [
                "CSF PR.AA-04"
              ]
            }
          ]
        },
        {
          "title": "PR.AT — 意識向上とトレーニング",
          "questions": [
            {
              "no": "PR.5",
              "text": "全従業員に対して定期的なサイバーセキュリティ意識向上トレーニング（フィッシング訓練含む）が実施されている",
              "refs": [
                "CSF PR.AT-01"
              ]
            },
            {
              "no": "PR.6",
              "text": "IT管理者・開発者・CISO等の役割に応じた専門的なセキュリティトレーニングが実施されている",
              "refs": [
                "CSF PR.AT-02"
              ]
            }
          ]
        },
        {
          "title": "PR.DS — データセキュリティ",
          "questions": [
            {
              "no": "PR.7",
              "text": "機密データが保存中（データベース・ストレージ・バックアップ）に暗号化されている",
              "refs": [
                "CSF PR.DS-01"
              ]
            },
            {
              "no": "PR.8",
              "text": "機密データが転送中（ネットワーク通信）にTLS等の暗号化で保護されている",
              "refs": [
                "CSF PR.DS-02"
              ]
            },
            {
              "no": "PR.9",
              "text": "データのバックアップが定期的に取得され、復元テストが実施されており、ランサムウェアに耐性のある隔離保管がされている",
              "refs": [
                "CSF PR.DS-03"
              ]
            },
            {
              "no": "PR.10",
              "text": "データの不正な持ち出しを防止するDLP（Data Loss Prevention）等の技術的対策が実装されている",
              "refs": [
                "CSF PR.DS-04"
              ]
            }
          ]
        },
        {
          "title": "PR.PS — プラットフォームセキュリティ",
          "questions": [
            {
              "no": "PR.11",
              "text": "OSおよびソフトウェアのセキュリティパッチが、定められたSLA（緊急：72時間以内等）に基づいて適用されている",
              "refs": [
                "CSF PR.PS-01"
              ]
            },
            {
              "no": "PR.12",
              "text": "CIS Benchmarks等に基づくセキュリティベースライン設定が全システムに適用され、ドリフトが検出されている",
              "refs": [
                "CSF PR.PS-02"
              ]
            },
            {
              "no": "PR.13",
              "text": "EDR・マルウェア対策ソフトが全エンドポイントに展開され、最新状態に維持されている",
              "refs": [
                "CSF PR.PS-03"
              ]
            },
            {
              "no": "PR.14",
              "text": "ネットワークが適切にセグメント分割されており、重要システムが一般ネットワークから隔離されている",
              "refs": [
                "CSF PR.PS-04"
              ]
            }
          ]
        },
        {
          "title": "PR.IR — テクノロジーインフラの耐障害性",
          "questions": [
            {
              "no": "PR.15",
              "text": "重要システムに冗長構成（HA・マルチAZ・フェールオーバー）が実装され、RTO/RPO目標が定義されている",
              "refs": [
                "CSF PR.IR-01"
              ]
            },
            {
              "no": "PR.16",
              "text": "DDoS攻撃等のサービス妨害攻撃に対する対策（緩和サービス・レート制限等）が実装されている",
              "refs": [
                "CSF PR.IR-02"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "csf_de",
      "label": "DE. 検知",
      "ref": "DETECT",
      "subsections": [
        {
          "title": "DE.CM — 継続的監視",
          "questions": [
            {
              "no": "DE.1",
              "text": "ネットワーク・エンドポイント・クラウド環境を継続的に監視するSIEM/SOC体制が確立されている",
              "refs": [
                "CSF DE.CM-01"
              ]
            },
            {
              "no": "DE.2",
              "text": "ユーザー・管理者・システムの活動ログが収集・保管（改ざん防止）されており、異常検知に活用されている",
              "refs": [
                "CSF DE.CM-02"
              ]
            },
            {
              "no": "DE.3",
              "text": "外部の脅威インテリジェンス（IoC）がセキュリティ監視ツールに自動的に反映されている",
              "refs": [
                "CSF DE.CM-03"
              ]
            },
            {
              "no": "DE.4",
              "text": "DNSクエリ・Webアクセス・電子メールのトラフィックが監視され、悪意ある通信を検知できる体制が整っている",
              "refs": [
                "CSF DE.CM-04"
              ]
            },
            {
              "no": "DE.5",
              "text": "物理的なセキュリティエリアへの不正アクセスを検知するための監視カメラ・センサーが設置されている",
              "refs": [
                "CSF DE.CM-05"
              ]
            }
          ]
        },
        {
          "title": "DE.AE — 有害事象の分析",
          "questions": [
            {
              "no": "DE.6",
              "text": "セキュリティアラートのトリアージ・分類・エスカレーション手順が定義されており、MTTD（平均検知時間）が測定されている",
              "refs": [
                "CSF DE.AE-01"
              ]
            },
            {
              "no": "DE.7",
              "text": "複数のデータソース（ログ・アラート・脅威情報）を相関分析し、インシデントの全体像を把握できる仕組みが整っている",
              "refs": [
                "CSF DE.AE-02"
              ]
            },
            {
              "no": "DE.8",
              "text": "インシデントの影響範囲・深刻度を評価し、適切な対応チームにエスカレーションするプロセスが確立されている",
              "refs": [
                "CSF DE.AE-03"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "csf_rs",
      "label": "RS. 対応",
      "ref": "RESPOND",
      "subsections": [
        {
          "title": "RS.MA — インシデント管理",
          "questions": [
            {
              "no": "RS.1",
              "text": "インシデント対応計画（IRP）が策定・承認され、担当者・役割・連絡先が明確に定義されている",
              "refs": [
                "CSF RS.MA-01"
              ]
            },
            {
              "no": "RS.2",
              "text": "インシデントの分類・優先度付け・エスカレーション基準が定義され、一貫して適用されている",
              "refs": [
                "CSF RS.MA-02"
              ]
            },
            {
              "no": "RS.3",
              "text": "インシデント対応の机上演習・訓練が年1回以上実施され、IRPが最新化されている",
              "refs": [
                "CSF RS.MA-03"
              ]
            }
          ]
        },
        {
          "title": "RS.AN — インシデント分析",
          "questions": [
            {
              "no": "RS.4",
              "text": "インシデント発生時にフォレンジック証拠（ログ・メモリ・ディスクイメージ）を適切に保全できる手順と体制が整っている",
              "refs": [
                "CSF RS.AN-01"
              ]
            },
            {
              "no": "RS.5",
              "text": "インシデントの根本原因分析（RCA）が実施され、再発防止策が策定・実施されている",
              "refs": [
                "CSF RS.AN-02"
              ]
            }
          ]
        },
        {
          "title": "RS.CO — インシデント対応報告",
          "questions": [
            {
              "no": "RS.6",
              "text": "インシデントを社内関係者（経営層・CISO・法務）および規制当局・顧客等に適切なタイミングで報告する手順が確立されている",
              "refs": [
                "CSF RS.CO-01"
              ]
            },
            {
              "no": "RS.7",
              "text": "情報漏洩インシデントが発生した際の個人情報保護委員会への報告（72時間以内）手順が整備されている",
              "refs": [
                "CSF RS.CO-02"
              ]
            }
          ]
        },
        {
          "title": "RS.MI — インシデント緩和",
          "questions": [
            {
              "no": "RS.8",
              "text": "インシデント発生時に感染端末の隔離・アカウント無効化・トラフィック遮断等の封じ込め措置を迅速に実施できる",
              "refs": [
                "CSF RS.MI-01"
              ]
            },
            {
              "no": "RS.9",
              "text": "マルウェアの根絶・脆弱性の修正・設定変更等の根絶措置を実施した後、システムの完全性を確認するプロセスがある",
              "refs": [
                "CSF RS.MI-02"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "csf_rc",
      "label": "RC. 復旧",
      "ref": "RECOVER",
      "subsections": [
        {
          "title": "RC.RP — インシデント復旧計画",
          "questions": [
            {
              "no": "RC.1",
              "text": "インシデント後のシステム復旧手順（DR計画）が文書化されており、RTO/RPO目標値が定義されている",
              "refs": [
                "CSF RC.RP-01"
              ]
            },
            {
              "no": "RC.2",
              "text": "DR訓練・フェールオーバーテストが年1回以上実施され、RTO/RPO目標の達成を実際に確認している",
              "refs": [
                "CSF RC.RP-02"
              ]
            },
            {
              "no": "RC.3",
              "text": "重要システムの復旧後に、セキュリティ設定・完全性・正常動作を確認するチェックリストが整備されている",
              "refs": [
                "CSF RC.RP-03"
              ]
            }
          ]
        },
        {
          "title": "RC.CO — 復旧時のコミュニケーション",
          "questions": [
            {
              "no": "RC.4",
              "text": "インシデントからの復旧状況を内部関係者・顧客・パートナー・規制当局に適切に伝えるコミュニケーション計画が整備されている",
              "refs": [
                "CSF RC.CO-01"
              ]
            },
            {
              "no": "RC.5",
              "text": "インシデント後のレビュー（Post-Incident Review）が実施され、教訓が次のBCP/DRPの改善に反映されている",
              "refs": [
                "CSF RC.CO-02"
              ]
            }
          ]
        }
      ]
    }
  ]
}